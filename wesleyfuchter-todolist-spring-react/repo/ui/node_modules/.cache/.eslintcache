[{"/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/index.js":"1","/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/reportWebVitals.js":"2","/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/App.js":"3","/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/TaskList.js":"4","/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/task-service.js":"5"},{"size":500,"mtime":1775163536370,"results":"6","hashOfConfig":"7"},{"size":362,"mtime":1775163536370,"results":"8","hashOfConfig":"7"},{"size":1659,"mtime":1775163536369,"results":"9","hashOfConfig":"7"},{"size":2941,"mtime":1775163536369,"results":"10","hashOfConfig":"7"},{"size":1868,"mtime":1775164099438,"results":"11","hashOfConfig":"7"},{"filePath":"12","messages":"13","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"1ai9vlk",{"filePath":"14","messages":"15","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"16","messages":"17","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"18","messages":"19","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"20"},{"filePath":"21","messages":"22","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/index.js",[],"/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/reportWebVitals.js",[],"/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/App.js",[],"/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/TaskList.js",["23","24"],"import './TaskList.css';\nimport { useEffect, useState } from 'react';\nimport { Card, Checkbox, Fab, TextField, Button } from '@material-ui/core';\nimport { findAllDone, findAllPending, setAsDone, setAsPending, save } from './task-service';\nimport AddIcon from '@material-ui/icons/Add';\n\nexport function TaskList({done}) {\n\n    const [tasks, setTasks] = useState([]);\n    const [isAdding, setIsAdding] = useState(false);\n    const [title, setTitle] = useState(null);\n\n    async function findAll() {\n        if (done) {\n            const doneTasks = await findAllDone();\n            setTasks(doneTasks);\n        } else {\n            const pendingTasks = await findAllPending();\n            setTasks(pendingTasks);\n        }\n    }\n\n    useEffect(async () => {\n        await findAll();\n    }, []);\n\n    async function onChange(target, task) {\n        if (target.checked) {\n            await setAsDone(task);\n        } else {\n            await setAsPending(task);\n        }\n        await findAll();\n    }\n\n    function onClickToAdd() {\n        console.log('rolou');\n        setIsAdding(true);\n    }\n\n    async function onSave() {\n        await save({\n            title,\n            done: false,\n        });\n        setIsAdding(false);\n        await findAll();\n    }\n\n    return (\n        <>\n            <ul>\n                {tasks.filter(task => task.done === done).map(task => {\n                    return (\n                        <Card className={'item-list-card'} key={task.id}>\n                            <Checkbox checked={task.done} value={task.id} onChange={({target}) => onChange(target, task)}/>\n                            {task.title} \n                        </Card>\n                    )\n                })}\n\n                {isAdding && <Card className={'item-list-card'} key={0}>\n                                <TextField\n                                        autoFocus\n                                        margin=\"dense\"\n                                        id=\"description\"\n                                        label=\"Description\"\n                                        type=\"text\"\n                                        fullWidth\n                                        onChange={(event) => setTitle(event.target.value)}\n                                    />\n                                    <Button onClick={() => setIsAdding(false)} variant=\"contained\" color=\"secondary\">\n                                        Cancel\n                                    </Button>\n                                    <Button onClick={() => onSave()} variant=\"contained\" color=\"primary\">\n                                        Submit\n                                    </Button>\n                            </Card>\n                        }\n\n            </ul>\n\n            \n\n            {!done && <Fab onClick={onClickToAdd} className={'fab-button'} color=\"primary\" aria-label=\"Add\"><AddIcon/></Fab>}\n        </>\n\n    );\n}","/Users/edburns/workareas/dd-2844946-demo/wesleyfuchter-todolist-spring-react/repo/ui/src/task-service.js",[],{"ruleId":"25","severity":1,"message":"26","line":23,"column":15,"nodeType":"27","endLine":25,"endColumn":6},{"ruleId":"25","severity":1,"message":"28","line":25,"column":8,"nodeType":"29","endLine":25,"endColumn":10,"suggestions":"30"},"react-hooks/exhaustive-deps","Effect callbacks are synchronous to prevent race conditions. Put the async function inside:\n\nuseEffect(() => {\n  async function fetchData() {\n    // You can await here\n    const response = await MyAPI.getData(someId);\n    // ...\n  }\n  fetchData();\n}, [someId]); // Or [] if effect doesn't need props or state\n\nLearn more about data fetching with Hooks: https://reactjs.org/link/hooks-data-fetching","ArrowFunctionExpression","React Hook useEffect has a missing dependency: 'findAll'. Either include it or remove the dependency array.","ArrayExpression",["31"],{"desc":"32","fix":"33"},"Update the dependencies array to be: [findAll]",{"range":"34","text":"35"},[788,790],"[findAll]"]